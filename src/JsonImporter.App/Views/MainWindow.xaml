<Window x:Class="JsonImporter.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JsonImporter.App.Views"
        mc:Ignorable="d"
        Title="JSON Importer" Height="560" Width="900" MinWidth="700" MinHeight="440"
        Icon="pack://application:,,,/icon.ico">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.1*" />
        </Grid.RowDefinitions>

        <!-- 제목 / 안내 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="JSON Importer" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="{Binding AppVersion}" Foreground="Gray" FontSize="12"
                           VerticalAlignment="Bottom" Margin="8,0,0,2" />
            </StackPanel>
            <TextBlock Foreground="Gray" TextWrapping="Wrap"
                       Text="각 테이블의 Google Sheets TSV export URL을 입력하세요. 예: https://docs.google.com/spreadsheets/d/&lt;id&gt;/export?format=tsv&amp;gid=0" />
        </StackPanel>

        <!-- 열 머리글 -->
        <Grid Grid.Row="1" Margin="0,4,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="테이블 이름" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="TSV Export URL" FontWeight="SemiBold" Margin="6,0" />
            <TextBlock Grid.Column="2" Text="상태" FontWeight="SemiBold" />
        </Grid>

        <!-- 테이블 행 목록 (동적 추가/삭제) -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                <ItemsControl ItemsSource="{Binding Tables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Margin="6,0" VerticalContentAlignment="Center"
                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Status}" />
                                <Button Grid.Column="3" Content="Import" Padding="10,3" Margin="2,0"
                                        Command="{Binding DataContext.ImportOneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                                <Button Grid.Column="4" Content="✕" Padding="8,3" Margin="2,0"
                                        ToolTip="이 테이블 삭제"
                                        Command="{Binding DataContext.RemoveTableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 테이블 추가 -->
        <Button Grid.Row="3" HorizontalAlignment="Left" Margin="0,8" Padding="12,5"
                Content="+ 테이블 추가" Command="{Binding AddTableCommand}" />

        <!-- 출력 경로 -->
        <Grid Grid.Row="4" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="출력 경로:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" VerticalContentAlignment="Center"
                     Text="{Binding OutputRoot, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2" Content="찾아보기…" Margin="6,0,0,0" Padding="10,3"
                    Command="{Binding BrowseOutputCommand}" />
            <Button Grid.Column="3" Content="열기" Margin="6,0,0,0" Padding="10,3"
                    Command="{Binding OpenOutputFolderCommand}" />
        </Grid>

        <!-- 전체 Import -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8">
            <Button Content="전체 Import" Padding="20,7" FontWeight="Bold"
                    Command="{Binding ImportAllCommand}" />
        </StackPanel>

        <!-- 로그 -->
        <DockPanel Grid.Row="6" Margin="0,6,0,0">
            <TextBlock DockPanel.Dock="Top" Text="로그" FontWeight="SemiBold" Margin="0,0,0,4" />
            <Grid x:Name="LogArea">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 정사각형 이미지(앱 아이콘): 로그 영역(LogArea) 높이에 맞추고, 폭=높이로 정사각형 유지 -->
                <Image Grid.Column="0" Source="pack://application:,,,/icon.ico" Stretch="Uniform"
                       Margin="0,0,8,0"
                       Height="{Binding ActualHeight, ElementName=LogArea}"
                       Width="{Binding ActualHeight, ElementName=LogArea}" />

                <!-- 로그 기록 창 -->
                <TextBox Grid.Column="1" x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="#DCDCDC"
                         Text="{Binding Log, Mode=OneWay}" TextChanged="LogBox_TextChanged" />
            </Grid>
        </DockPanel>
    </Grid>
</Window>
